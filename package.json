{
  "name": "very-light-cms",
  "version": "0.1.0",
  "description": "A solid, minimal, headless CMS. No magic, no black boxes.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "build:cli": "tsc && chmod +x dist/cli/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.9.1",
    "gray-matter": "^4.0.3",
    "hono": "^4.7.7",
    "jsonwebtoken": "^9.0.3",
    "marked": "^15.0.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "bin": {
    "vlcms": "./dist/cli/index.js"
  }
}
