# Very Light CMS — Environment Variables
# Copy to .env. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3344
NODE_ENV=development          # production | development

# ── Database (SQLite) ─────────────────────────────────────────────────────────
DB_PATH=./data/cms.db         # use ":memory:" for ephemeral

# ── Content + media ───────────────────────────────────────────────────────────
CONTENT_DIR=./content/pages   # markdown source dir
UPLOAD_DIR=./uploads          # media files
SITE_TITLE=My Site            # public homepage title

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# REQUIRED — server fails to boot if unset. Use a long random string.
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=8h

# ── Security ──────────────────────────────────────────────────────────────────
# COOKIE_SECURE defaults to true. Override to false ONLY for local HTTP dev.
# Setting it false anywhere reachable over plain HTTP exposes the session cookie.
# COOKIE_SECURE=false

# TRUST_PROXY defaults to false. The server ignores X-Forwarded-For unless this
# is set to true, preventing attackers from spoofing per-request IPs to bypass
# the auth rate-limit. Set to true ONLY when running behind Caddy/nginx that
# strip & set XFF to the real connecting IP.
# TRUST_PROXY=true

# ── Seeding ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD set on the command line: ADMIN_PASSWORD=... npm run seed:admin
